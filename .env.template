# CourtReserve credentials
CR_EMAIL=your-email@example.com
CR_PASSWORD=your-password
CR_BASE_URL=https://app.courtreserve.com
# These are auto-derived but can be overridden:
# CR_LOGIN_URL=https://app.courtreserve.com/Account/Login
# CR_USERNAME=your-email@example.com

# Video processing
# Optional — defaults to <project_root>/videos if unset.
# Set to an absolute path if your recordings live elsewhere.
# VIDEO_DIR=/absolute/path/to/videos

# Server
PORT=3001

# Build output: dist goes to ../../www/$APP_NAME relative to web/
APP_NAME=sessionmanager

# Supabase — shared backend with wmpc_rating_hub
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ORG_SLUG=wmpc

# PB.vision Partner API — preferred path for uploading clips. Email
# support@pb.vision to request an API key for your partner account.
PBVISION_API_KEY=your-partner-api-key
# Optional: set to "1" to use pb.vision's test server instead of prod
# (sandbox; does not burn real credits). Defaults to prod.
# PBVISION_USE_TEST_SERVER=1

# PB.vision (legacy, browser-automation upload — kept as a fallback while
# we migrate to the Partner API. Not required if PBVISION_API_KEY is set.)
PB_VISION_EMAIL=your-email@example.com
PB_VISION_PASSWORD=your-password

# Rating Hub webhook — receives video IDs after each pb.vision upload so the
# rating-hub downloads insights and populates its DB. URL and secret come
# from the wmpc_rating_hub Supabase project (Edge Functions → pbvision-webhook).
RATING_HUB_WEBHOOK_URL=https://your-project.supabase.co/functions/v1/pbvision-webhook
RATING_HUB_WEBHOOK_SECRET=your-webhook-secret

# Base URL of the deployed rating-hub web app (used to deep-link back from
# session-manager after pushing a session to rating-hub).
RATING_HUB_BASE_URL=https://ratinghub.example.com

# Discord — operator alerts (e.g. CourtReserve sync failure). Use the same
# webhook URL the sibling courtreserve-scheduler app already uses so all
# alerts land in one channel. Leave blank to disable alerting; failures
# will still surface in the UI / session log.
DISCORD_WEBHOOK_URL=
